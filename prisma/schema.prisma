generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  discordRole String   // Discord role ID to assign
  image       String?
  category    String   // "vehicle", "house", "role", etc.
  stock       Int?     // null = unlimited
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FactionApplication {
  id            String   @id @default(uuid())
  discordUserId String
  discordUsername String
  faction       String   // "police", "staff", "firefighter", "dot", "sessionhost"
  questions     Json     // Store questions and answers
  status        String   @default("pending") // pending, accepted, rejected
  reviewedBy    String?
  reviewNote    String?
  discordRoleId String?  // Discord role ID to assign on acceptance
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FactionRole {
  id            String   @id @default(uuid())
  faction       String   @unique // "police", "staff", "firefighter", "dot", "sessionhost"
  discordRoleId String   // Discord role ID for this faction
  name          String   // Display name
  description   String?
  color         String   // Hex color for embeds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id            String   @id @default(uuid())
  discordUserId String   @unique
  discordUsername String @unique
  passwordHash  String?  // For login
  role          String   @default("admin") // admin, moderator
  active        Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteConfig {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  updatedAt     DateTime @updatedAt
}
